require 'fileutils'
require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, '15.1'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'WalkingRPGTemp' do
  config = use_native_modules!
  use_modular_headers!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'WalkingRPGTempTests' do
    inherit! :complete
    pod 'Detox', :path => '../node_modules/detox'
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => true
    )

    # React-RuntimeApple (new in RN 0.77) defines 'module ReactCommon' in its modulemap,
    # colliding with ReactCommon.modulemap when use_modular_headers! passes both via
    # -fmodule-map-file= to every compilation unit. Both define the same module name and
    # both use 'umbrella header' for the same directory — Clang rejects this.
    # Fix: remove React-RuntimeApple.modulemap from the global -fmodule-map-file= flags.
    # The React-RuntimeApple target itself still uses MODULEMAP_FILE pointing to this file,
    # so its own compilation is unaffected. Other targets access the headers via HEADER_SEARCH_PATHS.
    Dir.glob("#{installer.sandbox.root}/Target Support Files/**/*.xcconfig").each do |path|
      content = File.read(path)
      next unless content.include?('ReactCommon/React-RuntimeApple.modulemap')
      fixed = content
        .gsub(' -fmodule-map-file="${PODS_ROOT}/Headers/Public/ReactCommon/React-RuntimeApple.modulemap"', '')
        .gsub(' -Xcc -fmodule-map-file="${PODS_ROOT}/Headers/Public/ReactCommon/React-RuntimeApple.modulemap"', '')
        .gsub(' -Xcc -Xcc -fmodule-map-file=', ' -Xcc -fmodule-map-file=')
      File.write(path, fixed)
    end

    # ReactNativeDependencies (RN 0.85 prebuilt) ships folly without the coro/ header directory.
    # Building with -std=c++20 sets FOLLY_HAS_COROUTINES=1 in folly/Portability.h, causing any
    # folly header that includes folly/coro/Coroutine.h to fail with a fatal missing-file error.
    # Patch all such headers (currently Expected.h and Optional.h) to guard with __has_include.
    [
      "#{installer.sandbox.root}/ReactNativeDependencies/Headers",
      "#{installer.sandbox.root}/ReactNativeDependencies/framework/packages/react-native/ReactNativeDependencies.xcframework/Headers",
    ].each do |folly_dir|
      Dir.glob("#{folly_dir}/folly/**/*.h").each do |header|
        content = File.read(header)
        next unless content.include?('<folly/coro/Coroutine.h>')
        patched = content.gsub(
          /^#if FOLLY_HAS_COROUTINES$/,
          '#if FOLLY_HAS_COROUTINES && __has_include(<folly/coro/Coroutine.h>)'
        )
        if patched != content
          FileUtils.chmod('u+w', header)
          File.write(header, patched)
        end
      end
    end

    # Fix gRPC-Core.modulemap not found — CocoaPods xcconfigs reference the module map at
    # Headers/Private/grpc/ but that directory is wiped by CocoaPods integration.
    # Fix the path in every xcconfig to point to the actual location in Target Support Files/.
    Dir.glob("#{installer.sandbox.root}/Target Support Files/**/*.xcconfig").each do |path|
      content = File.read(path)
      next unless content.include?('Headers/Private/grpc/gRPC-Core.modulemap')
      fixed = content.gsub(
        '"${PODS_ROOT}/Headers/Private/grpc/gRPC-Core.modulemap"',
        '"${PODS_ROOT}/Target Support Files/gRPC-Core/gRPC-Core.modulemap"'
      )
      File.write(path, fixed)
    end

    # Fix FirebaseAuth-Swift.h not found — Firebase SDK 12 moved FIRAuthErrorCode from
    # FIRAuthErrors.h (ObjC) to a Swift enum. The real FirebaseAuth-Swift.h is generated
    # by the Swift compiler, but ObjC compiles first. This stub satisfies ObjC compilation;
    # must be in Public so the FirebaseAuth module map resolves it via use_modular_headers!.
    firebase_auth_swift_stub = <<~STUB
      // Fallback stub for FirebaseAuth Swift types (Firebase SDK 12+).
      // Tries to include the real Swift-generated header from the build directory first.
      // $(PODS_CONFIGURATION_BUILD_DIR)/FirebaseAuth is prepended to HEADER_SEARCH_PATHS
      // by the Podfile post_install hook, so the quoted include below resolves to:
      //   $(PODS_CONFIGURATION_BUILD_DIR)/FirebaseAuth/Swift Compatibility Header/FirebaseAuth-Swift.h
      // which is the header the Swift compiler generates after building the FirebaseAuth target.
      // CocoaPods target dependency ordering guarantees FirebaseAuth builds before any
      // pod that imports it (Firebase, RNFBAuth, etc.), so the real header is always
      // present by the time dependents compile.
      #pragma once
      #import <Foundation/Foundation.h>

      #if __has_include("Swift Compatibility Header/FirebaseAuth-Swift.h")
      // Real Swift-generated header — all types fully declared.
      #import "Swift Compatibility Header/FirebaseAuth-Swift.h"
      #else
      // Fallback declarations for edge cases where the real header is not yet available.
      // In practice this branch is unused for any pod that depends on FirebaseAuth.

      // Forward declarations for types referenced before full definition
      @class FIRAuth;
      @class FIRAuthDataResult;
      @class FIRPhoneAuthCredential;
      @class FIRMultiFactorSession;
      @class FIRMultiFactorInfo;
      @class FIRMultiFactorAssertion;
      @class FIRPhoneMultiFactorAssertion;
      @class FIRTOTPMultiFactorAssertion;
      @class FIRTOTPSecret;

      NS_ASSUME_NONNULL_BEGIN

      // FIRUserInfo protocol (moved to Swift in Firebase SDK 12)
      @protocol FIRUserInfo <NSObject>
      @property (nonatomic, readonly, copy) NSString *providerID;
      @property (nonatomic, readonly, copy) NSString *uid;
      @property (nonatomic, readonly, copy, nullable) NSString *displayName;
      @property (nonatomic, readonly, copy, nullable) NSURL *photoURL;
      @property (nonatomic, readonly, copy, nullable) NSString *email;
      @property (nonatomic, readonly, copy, nullable) NSString *phoneNumber;
      @end

      // ActionCodeOperation enum (moved to Swift in Firebase SDK 12)
      typedef NS_ENUM(NSInteger, FIRActionCodeOperation) {
        FIRActionCodeOperationUnknown = 0,
        FIRActionCodeOperationPasswordReset = 1,
        FIRActionCodeOperationVerifyEmail = 2,
        FIRActionCodeOperationRecoverEmail = 3,
        FIRActionCodeOperationEmailLink = 4,
        FIRActionCodeOperationVerifyAndChangeEmail = 5,
        FIRActionCodeOperationRevertSecondFactorAddition = 6,
      };

      // ActionCodeInfo class (moved to Swift in Firebase SDK 12)
      @interface FIRActionCodeInfo : NSObject
      @property (nonatomic, readonly) FIRActionCodeOperation operation;
      @property (nonatomic, readonly, copy) NSString *email;
      @property (nonatomic, readonly, copy, nullable) NSString *previousEmail;
      @end

      // ActionCodeSettings class (moved to Swift in Firebase SDK 12)
      @interface FIRActionCodeSettings : NSObject
      @property (nonatomic, copy, nullable) NSURL *URL;
      @property (nonatomic) BOOL handleCodeInApp;
      @property (nonatomic, copy, nullable) NSString *iOSBundleID;
      @property (nonatomic, copy, nullable) NSString *androidPackageName;
      @property (nonatomic, copy, nullable) NSString *androidMinimumVersion;
      @property (nonatomic) BOOL androidInstallIfNotAvailable;
      @property (nonatomic, copy, nullable) NSString *linkDomain;
      - (instancetype)init;
      - (void)setAndroidPackageName:(NSString *)androidPackageName
              installIfNotAvailable:(BOOL)installIfNotAvailable
                     minimumVersion:(nullable NSString *)minimumVersion;
      @end

      // MultiFactorSession class (moved to Swift in Firebase SDK 12)
      @interface FIRMultiFactorSession : NSObject
      @end

      // MultiFactorInfo class (moved to Swift in Firebase SDK 12)
      @interface FIRMultiFactorInfo : NSObject
      @property (nonatomic, readonly, copy) NSString *UID;
      @property (nonatomic, readonly, copy, nullable) NSString *displayName;
      @property (nonatomic, readonly, copy) NSDate *enrollmentDate;
      @property (nonatomic, readonly, copy) NSString *factorID;
      @end

      // MultiFactorAssertion class (moved to Swift in Firebase SDK 12)
      @interface FIRMultiFactorAssertion : NSObject
      @property (nonatomic, copy) NSString *factorID;
      @end

      // MultiFactorResolver class (moved to Swift in Firebase SDK 12)
      @interface FIRMultiFactorResolver : NSObject
      @property (nonatomic, readonly, strong) FIRMultiFactorSession *session;
      @property (nonatomic, readonly, copy) NSArray<FIRMultiFactorInfo *> *hints;
      @property (nonatomic, readonly, strong) FIRAuth *auth;
      - (void)resolveSignInWithAssertion:(FIRMultiFactorAssertion *)assertion
                              completion:(nullable void (^)(FIRAuthDataResult * _Nullable, NSError * _Nullable))completion;
      @end

      // PhoneMultiFactorInfo class (moved to Swift in Firebase SDK 12)
      @interface FIRPhoneMultiFactorInfo : FIRMultiFactorInfo
      @property (nonatomic, readonly, copy) NSString *phoneNumber;
      @end

      // PhoneMultiFactorAssertion class (moved to Swift in Firebase SDK 12)
      @interface FIRPhoneMultiFactorAssertion : FIRMultiFactorAssertion
      @end

      // PhoneMultiFactorGenerator class (moved to Swift in Firebase SDK 12)
      @interface FIRPhoneMultiFactorGenerator : NSObject
      + (FIRPhoneMultiFactorAssertion *)assertionWithCredential:(FIRPhoneAuthCredential *)credential;
      @end

      // TOTPSecret class (moved to Swift in Firebase SDK 12)
      @interface FIRTOTPSecret : NSObject
      - (NSString *)sharedSecretKey;
      - (NSString *)generateQRCodeURLWithAccountName:(NSString *)accountName issuer:(NSString *)issuer;
      - (void)openInOTPAppWithQRCodeURL:(NSString *)qrCodeURL;
      @end

      // TOTPMultiFactorAssertion class (moved to Swift in Firebase SDK 12)
      @interface FIRTOTPMultiFactorAssertion : FIRMultiFactorAssertion
      @end

      // TOTPMultiFactorGenerator class (moved to Swift in Firebase SDK 12)
      @interface FIRTOTPMultiFactorGenerator : NSObject
      + (void)generateSecretWithMultiFactorSession:(FIRMultiFactorSession *)session
                                        completion:(void (^)(FIRTOTPSecret * _Nullable, NSError * _Nullable))completion;
      + (FIRTOTPMultiFactorAssertion *)assertionForEnrollmentWithSecret:(FIRTOTPSecret *)secret
                                                        oneTimePassword:(NSString *)oneTimePassword;
      + (FIRTOTPMultiFactorAssertion *)assertionForSignInWithEnrollmentID:(NSString *)enrollmentID
                                                          oneTimePassword:(NSString *)oneTimePassword;
      @end

      NS_ASSUME_NONNULL_END

      typedef NS_CLOSED_ENUM(NSInteger, FIRAuthErrorCode) {
        FIRAuthErrorCodeInvalidCustomToken = 17000,
        FIRAuthErrorCodeCustomTokenMismatch = 17002,
        FIRAuthErrorCodeInvalidCredential = 17004,
        FIRAuthErrorCodeUserDisabled = 17005,
        FIRAuthErrorCodeOperationNotAllowed = 17006,
        FIRAuthErrorCodeEmailAlreadyInUse = 17007,
        FIRAuthErrorCodeInvalidEmail = 17008,
        FIRAuthErrorCodeWrongPassword = 17009,
        FIRAuthErrorCodeTooManyRequests = 17010,
        FIRAuthErrorCodeUserNotFound = 17011,
        FIRAuthErrorCodeAccountExistsWithDifferentCredential = 17012,
        FIRAuthErrorCodeRequiresRecentLogin = 17014,
        FIRAuthErrorCodeProviderAlreadyLinked = 17015,
        FIRAuthErrorCodeNoSuchProvider = 17016,
        FIRAuthErrorCodeInvalidUserToken = 17017,
        FIRAuthErrorCodeNetworkError = 17020,
        FIRAuthErrorCodeUserTokenExpired = 17021,
        FIRAuthErrorCodeInvalidAPIKey = 17023,
        FIRAuthErrorCodeUserMismatch = 17024,
        FIRAuthErrorCodeCredentialAlreadyInUse = 17025,
        FIRAuthErrorCodeWeakPassword = 17026,
        FIRAuthErrorCodeAppNotAuthorized = 17028,
        FIRAuthErrorCodeExpiredActionCode = 17029,
        FIRAuthErrorCodeInvalidActionCode = 17030,
        FIRAuthErrorCodeInvalidMessagePayload = 17031,
        FIRAuthErrorCodeInvalidSender = 17032,
        FIRAuthErrorCodeInvalidRecipientEmail = 17033,
        FIRAuthErrorCodeMissingEmail = 17034,
        FIRAuthErrorCodeMissingIosBundleID = 17036,
        FIRAuthErrorCodeMissingAndroidPackageName = 17037,
        FIRAuthErrorCodeUnauthorizedDomain = 17038,
        FIRAuthErrorCodeInvalidContinueURI = 17039,
        FIRAuthErrorCodeMissingContinueURI = 17040,
        FIRAuthErrorCodeMissingPhoneNumber = 17041,
        FIRAuthErrorCodeInvalidPhoneNumber = 17042,
        FIRAuthErrorCodeMissingVerificationCode = 17043,
        FIRAuthErrorCodeInvalidVerificationCode = 17044,
        FIRAuthErrorCodeMissingVerificationID = 17045,
        FIRAuthErrorCodeInvalidVerificationID = 17046,
        FIRAuthErrorCodeMissingAppCredential = 17047,
        FIRAuthErrorCodeInvalidAppCredential = 17048,
        FIRAuthErrorCodeSessionExpired = 17051,
        FIRAuthErrorCodeQuotaExceeded = 17052,
        FIRAuthErrorCodeMissingAppToken = 17053,
        FIRAuthErrorCodeNotificationNotForwarded = 17054,
        FIRAuthErrorCodeAppNotVerified = 17055,
        FIRAuthErrorCodeCaptchaCheckFailed = 17056,
        FIRAuthErrorCodeWebContextAlreadyPresented = 17057,
        FIRAuthErrorCodeWebContextCancelled = 17058,
        FIRAuthErrorCodeAppVerificationUserInteractionFailure = 17059,
        FIRAuthErrorCodeInvalidClientID = 17060,
        FIRAuthErrorCodeWebNetworkRequestFailed = 17061,
        FIRAuthErrorCodeWebInternalError = 17062,
        FIRAuthErrorCodeWebSignInUserInteractionFailure = 17063,
        FIRAuthErrorCodeLocalPlayerNotAuthenticated = 17066,
        FIRAuthErrorCodeNullUser = 17067,
        FIRAuthErrorCodeInvalidProviderID = 17071,
        FIRAuthErrorCodeTenantIDMismatch = 17072,
        FIRAuthErrorCodeUnsupportedTenantOperation = 17073,
        FIRAuthErrorCodeRejectedCredential = 17075,
        FIRAuthErrorCodeGameKitNotLinked = 17076,
        FIRAuthErrorCodeSecondFactorRequired = 17078,
        FIRAuthErrorCodeMissingMultiFactorSession = 17081,
        FIRAuthErrorCodeMissingMultiFactorInfo = 17082,
        FIRAuthErrorCodeInvalidMultiFactorSession = 17083,
        FIRAuthErrorCodeMultiFactorInfoNotFound = 17084,
        FIRAuthErrorCodeAdminRestrictedOperation = 17085,
        FIRAuthErrorCodeUnverifiedEmail = 17086,
        FIRAuthErrorCodeSecondFactorAlreadyEnrolled = 17087,
        FIRAuthErrorCodeMaximumSecondFactorCountExceeded = 17088,
        FIRAuthErrorCodeUnsupportedFirstFactor = 17089,
        FIRAuthErrorCodeEmailChangeNeedsVerification = 17090,
        FIRAuthErrorCodeMissingClientIdentifier = 17093,
        FIRAuthErrorCodeMissingOrInvalidNonce = 17094,
        FIRAuthErrorCodeBlockingCloudFunctionError = 17105,
        FIRAuthErrorCodeInvalidHostingLinkDomain = 17214,
        FIRAuthErrorCodeRecaptchaNotEnabled = 17200,
        FIRAuthErrorCodeMissingRecaptchaToken = 17201,
        FIRAuthErrorCodeInvalidRecaptchaToken = 17202,
        FIRAuthErrorCodeInvalidRecaptchaAction = 17203,
        FIRAuthErrorCodeMissingClientType = 17204,
        FIRAuthErrorCodeMissingRecaptchaVersion = 17205,
        FIRAuthErrorCodeInvalidRecaptchaVersion = 17206,
        FIRAuthErrorCodeInvalidReqType = 17207,
        FIRAuthErrorCodeRecaptchaSDKNotLinked = 17208,
        FIRAuthErrorCodeRecaptchaSiteKeyMissing = 17209,
        FIRAuthErrorCodeRecaptchaActionCreationFailed = 17210,
        FIRAuthErrorCodeKeychainError = 17995,
        FIRAuthErrorCodeInternalError = 17999,
        FIRAuthErrorCodeMalformedJWT = 18000,
      };
      #endif
    STUB
    [
      "#{installer.sandbox.root}/Headers/Public/FirebaseAuth",
      "#{installer.sandbox.root}/Headers/Private/FirebaseAuth",
    ].each do |dir|
      FileUtils.mkdir_p(dir)
      File.write("#{dir}/FirebaseAuth-Swift.h", firebase_auth_swift_stub)
    end

    # FirebaseFirestoreInternal is a static library (.a), not a framework.
    # The FirebaseFirestore podspec incorrectly emits -weak_framework for it,
    # which causes "Framework not found FirebaseFirestoreInternal" at link time.
    # Strip the bad flag from every aggregate xcconfig that contains it.
    Dir.glob("#{installer.sandbox.root}/Target Support Files/**/*.xcconfig").each do |path|
      content = File.read(path)
      next unless content.include?('-weak_framework "FirebaseFirestoreInternal"')
      File.write(path, content.gsub(' -weak_framework "FirebaseFirestoreInternal"', ''))
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
        cxx_flags = Array(config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)')
        cxx_flags += ['-Wno-deprecated-literal-operator'] unless cxx_flags.any? { |f| f.include?('deprecated-literal-operator') }
        # ReactNativeDependencies (RN 0.85 prebuilt) ships folly without the coro/ headers.
        # C++20 makes FOLLY_HAS_COROUTINES=1, causing Expected.h to include the missing
        # folly/coro/Coroutine.h. This flag uses folly's official opt-out to match the prebuilt.
        cxx_flags += ['-DFOLLY_CFG_NO_COROUTINES'] unless cxx_flags.any? { |f| f.include?('FOLLY_CFG_NO_COROUTINES') }
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxx_flags
        # Firebase SDK 12 moved most public types to Swift. The real FirebaseAuth-Swift.h
        # is generated by Xcode's Swift compiler into PODS_CONFIGURATION_BUILD_DIR/FirebaseAuth/.
        # CocoaPods dependency ordering guarantees FirebaseAuth's Swift compiles before any
        # pod that depends on it, so prepending this path finds the real header first.
        # The stub in Headers/Public/FirebaseAuth/ acts as a fallback.
        existing = Array(config.build_settings['HEADER_SEARCH_PATHS'] || '$(inherited)')
        unless existing.any? { |p| p.include?('PODS_CONFIGURATION_BUILD_DIR)/FirebaseAuth') }
          config.build_settings['HEADER_SEARCH_PATHS'] =
            ['"$(PODS_CONFIGURATION_BUILD_DIR)/FirebaseAuth"'] + existing
        end

        # Raise any pod deployment target below the app's 15.1 minimum to suppress warnings
        current_target = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        if current_target && Gem::Version.new(current_target) < Gem::Version.new('15.1')
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
        end

        # Deduplicate -lc++ in OTHER_LDFLAGS
        ldflags = config.build_settings['OTHER_LDFLAGS']
        if ldflags.is_a?(Array) && ldflags.count('-lc++') > 1
          ldflags.delete('-lc++')
          ldflags << '-lc++'
          config.build_settings['OTHER_LDFLAGS'] = ldflags
        end
      end
    end
  end
end
