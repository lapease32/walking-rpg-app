# OSX
.DS_Store

# Xcode
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
project.xcworkspace
ios/.xcode.env.local

# Android/IntelliJ
build/
.idea
.gradle
local.properties
*.iml
*.hprof

# Signing — never commit a release keystore (the RN debug.keystore is intentionally tracked)
*.jks
*.keystore
!android/app/debug.keystore
.cxx/
# Android bug reports (generated by Android Studio on crashes)
android/bugreport-*.zip

# node.js
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
# iOS fastlane lives in ios/fastlane (the patterns above are repo-root anchored, so they don't
# cover it) — ignore its run artifacts + the signed build output produced by the beta lane.
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/README.md
ios/fastlane/test_output
ios/*.ipa
ios/*.app.dSYM.zip
# ios/fastlane's Gemfile.lock is intentionally NOT committed: CI (ruby/setup-ruby bundler-cache)
# regenerates it, and committing it pulls fastlane's dev-only transitive gems (e.g. the high-sev
# faraday ReDoS advisory — build tooling, never shipped) into the Dependency Review gate, which
# would block unrelated PRs. Keep it local.
ios/Gemfile.lock

# Bundle artifacts
*.jsbundle

# CocoaPods
/ios/Pods/

# Expo
.expo/
.expo-shared/

# Metro
.metro-health-check*

# Environment
.env
.env.local

# Firebase/Google Services (contains API keys - never commit these)
android/app/google-services.json
ios/**/GoogleService-Info.plist

# Debug
.vscode/
.idea/

# Personal documentation (not for other developers)
docs/personal/

#Release folder
releases/

# Local Claude Code state (accumulated permission allowlist, local overrides, lock) — not project code
.claude/

# Local debug / test artifacts pulled down while diagnosing CI
logcat-android/
maestro-android-results/

# Stray AI-generated image downloads
openart-*.png

# Build / tool logs (regenerated — e.g. ios/pod-install.log, rewritten on every pod install)
*.log